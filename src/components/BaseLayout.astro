---
import '../styles/global.css';
import BrandMark from '@/components/BrandMark.astro';
import { profile } from '@/config/profile';
import type { Lang } from '@/i18n';
import { getLangPath, ui } from '@/i18n';

interface Props {
  title: string;
  description: string;
  lang?: Lang;
  currentPath?: string;
}

const { title, description, lang = 'zh', currentPath = '/' } = Astro.props;
const pageTitle = `${title} | ${profile.siteName}`;
const t = ui[lang];
---

<!doctype html>
<html lang={lang === 'zh' ? 'zh-Hant' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-sky-300 focus:px-4 focus:py-2 focus:text-slate-950" href="#main">
      Skip to main content
    </a>
    <header class="sticky top-0 z-40 border-b border-white/10 bg-slate-950/[0.82] backdrop-blur">
      <nav class="mx-auto flex max-w-6xl items-center justify-between gap-2 px-4 py-4 sm:gap-4 sm:px-5">
        <a href="/" class="flex items-center gap-2 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-sky-200 sm:text-sm">
          <BrandMark className="h-7 w-7 shrink-0" decorative />
          {profile.siteName}
        </a>
        <div class="flex items-center gap-1 text-xs text-slate-300 sm:gap-2 sm:text-sm">
          <a class="rounded-md px-2 py-2 transition hover:bg-white/[0.08] hover:text-white sm:px-3" href={`/${lang}/`}>{t.navHome}</a>
          <a class="rounded-md px-2 py-2 transition hover:bg-white/[0.08] hover:text-white sm:px-3" href={`/${lang}/blog/`}>{t.navBlog}</a>
          <a class="rounded-md px-2 py-2 transition hover:bg-white/[0.08] hover:text-white sm:px-3" href={`/${lang}/demos/`}>{t.navDemos}</a>
          <a class="rounded-md px-2 py-2 transition hover:bg-white/[0.08] hover:text-white sm:px-3" href={`/${lang}/resume/`}>{t.navResume}</a>
          <span class="mx-0.5 h-5 w-px bg-white/10 sm:mx-1" aria-hidden="true"></span>
          <a class={`rounded-md px-2 py-2 font-mono text-xs ${lang === 'zh' ? 'bg-sky-300/15 text-sky-100' : 'hover:bg-white/[0.08] hover:text-white'}`} href={getLangPath('zh', currentPath)}>ZH</a>
          <a class={`rounded-md px-2 py-2 font-mono text-xs ${lang === 'en' ? 'bg-sky-300/15 text-sky-100' : 'hover:bg-white/[0.08] hover:text-white'}`} href={getLangPath('en', currentPath)}>EN</a>
        </div>
      </nav>
    </header>
    <main id="main">
      <slot />
    </main>
    <footer class="border-t border-white/10 px-5 py-10">
      <div class="mx-auto flex max-w-6xl flex-col gap-4 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
        <p>© {new Date().getFullYear()} {profile.siteName}. Security notes by {profile.name}.</p>
        <div class="flex flex-wrap gap-4">
          <a class="hover:text-sky-200" href={`mailto:${profile.email}`}>Email</a>
          <a class="hover:text-sky-200" href={profile.github}>GitHub</a>
        </div>
      </div>
    </footer>
  </body>
</html>

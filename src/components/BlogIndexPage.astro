---
import type { CollectionEntry } from 'astro:content';
import ArticleCard from '@/components/ArticleCard.astro';
import BaseLayout from '@/components/BaseLayout.astro';
import type { Lang } from '@/i18n';
import { ui } from '@/i18n';

interface Props {
  lang: Lang;
  posts: CollectionEntry<'blog'>[];
}

const { lang, posts } = Astro.props;
const t = ui[lang];
const searchItems = posts.map((post) => ({
  id: post.id,
  text: [post.data.title, post.data.description, post.data.tags.join(' '), post.body ?? ''].join(' ').toLowerCase()
}));
---

<BaseLayout title="Blog" description={`${t.blogTitle} by language.`} lang={lang} currentPath="/blog/">
  <section class="px-5 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Cyber security blog</p>
        <h1 class="mt-4 text-4xl font-bold text-white sm:text-5xl">{t.blogTitle}</h1>
        <p class="mt-5 text-lg leading-8 text-slate-300">{t.blogIntro}</p>
      </div>

      <div class="mt-8">
        <label class="mb-2 block text-sm font-semibold text-slate-200" for="article-search">{t.searchLabel}</label>
        <input
          id="article-search"
          class="w-full rounded-lg border border-white/15 bg-slate-950/60 px-4 py-3 text-base text-white outline-none transition placeholder:text-slate-500 focus:border-sky-300"
          type="search"
          placeholder={t.searchPlaceholder}
          data-search-input
          autocomplete="off"
        />
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-2" data-testid="blog-list">
        {posts.map((post, index) => (
          <div data-post-id={post.id}>
            <ArticleCard post={post} lang={lang} index={index} />
          </div>
        ))}
      </div>
      <p class="mt-8 hidden rounded-lg border border-white/10 bg-slate-950/55 p-5 text-slate-300" data-no-results>
        {t.noResults}
      </p>
    </div>
  </section>

  <script is:inline define:vars={{ searchItems }}>
    const input = document.querySelector('[data-search-input]');
    const cards = Array.from(document.querySelectorAll('[data-post-id]'));
    const noResults = document.querySelector('[data-no-results]');

    input?.addEventListener('input', () => {
      const query = input.value.trim().toLowerCase();
      let visibleCount = 0;

      for (const card of cards) {
        const item = searchItems.find((entry) => entry.id === card.dataset.postId);
        const isVisible = !query || item?.text.includes(query);
        card.hidden = !isVisible;
        if (isVisible) visibleCount += 1;
      }

      noResults?.classList.toggle('hidden', visibleCount !== 0);
    });
  </script>
</BaseLayout>

---
import { categoryLabels } from './demo-data';
import type { DemoEntry } from './demo-data';

interface Props {
  demo: DemoEntry;
  lang: 'en' | 'zh';
}

const { demo, lang } = Astro.props;
const title = lang === 'zh' ? demo.titleZh : demo.title;
const desc = lang === 'zh' ? demo.descriptionZh : demo.description;
const cat = categoryLabels[demo.category]?.[lang] ?? demo.category;
const href = `/${lang}/demos/${demo.id}/`;
---

<a
  href={href}
  class="group hud-panel block rounded-lg border border-white/5 p-5 transition hover:border-sky-300/30 hover:bg-white/[0.02]"
>
  <div class="mb-3 flex items-start justify-between gap-2">
    <span class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-1 font-mono text-xs text-slate-400">
      {cat}
    </span>
    {demo.status === 'coming_soon' && (
      <span class="rounded-md border border-amber-300/20 bg-amber-300/[0.08] px-2 py-1 font-mono text-xs text-amber-200">
        Coming Soon
      </span>
    )}
  </div>
  <h3 class="text-lg font-semibold leading-6 text-white group-hover:text-sky-100">{title}</h3>
  <p class="mt-2 line-clamp-2 text-sm leading-6 text-slate-400">{desc}</p>
  <div class="mt-4 flex flex-wrap items-center gap-2">
    {(demo.platforms.slice(0, 3)).map((p: string) => (
      <span class="rounded-md border border-white/5 bg-white/[0.02] px-2 py-0.5 font-mono text-xs text-slate-500">{p}</span>
    ))}
    <span class={`ml-auto rounded-md px-2 py-0.5 font-mono text-xs ${demo.difficulty === 'beginner' ? 'text-emerald-200 border-emerald-300/20 bg-emerald-300/[0.08]' : demo.difficulty === 'intermediate' ? 'text-amber-200 border-amber-300/20 bg-amber-300/[0.08]' : 'text-rose-200 border-rose-300/20 bg-rose-300/[0.08]'}`}>
      {demo.difficulty}
    </span>
  </div>
</a>
---

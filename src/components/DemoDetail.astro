---
import BaseLayout from '@/components/BaseLayout.astro';
import type { DemoEntry } from '@/components/demo-types';
import { getCategoryLabel, difficultyClass } from '@/components/demo-types';
import type { Lang } from '@/i18n';

interface Props {
  lang: Lang;
  demo: DemoEntry;
}

const { lang, demo } = Astro.props;
const title = lang === 'zh' ? demo.titleZh : demo.title;
const desc = lang === 'zh' ? demo.descriptionZh : demo.description;
const cat = getCategoryLabel(demo.category, lang);
const pageTitle = `${title} | ${lang === 'zh' ? '攻防示範' : 'Attack Demo'}`;
const pageDesc = desc;
---

<BaseLayout title={pageTitle} description={pageDesc} lang={lang} currentPath={`/demos/${demo.id}/`}>
  <section class="px-5 py-14">
    <div class="mx-auto max-w-4xl">
      <a
        href={`/${lang}/demos/`}
        class="font-semibold text-sky-200 hover:text-sky-100"
      >
        &larr; {lang === 'zh' ? '返回示範目錄' : 'Back to Demos'}
      </a>

      <div class="mt-6 border-b border-white/10 pb-8">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <span class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-1 font-mono text-xs text-slate-400">{cat}</span>
          <span class={`rounded-md px-2 py-1 font-mono text-xs ${difficultyClass(demo.difficulty)}`}>{demo.difficulty}</span>
          {demo.estimated_duration && (
            <span class="font-mono text-xs text-slate-400">&middot; {demo.estimated_duration}</span>
          )}
          {demo.status === 'coming_soon' && (
            <span class="rounded-md border border-amber-300/20 bg-amber-300/[0.08] px-2 py-1 font-mono text-xs text-amber-200">Coming Soon</span>
          )}
        </div>
        <h1 class="text-3xl font-bold leading-tight text-white sm:text-4xl">{title}</h1>
        <p class="mt-4 text-lg leading-8 text-slate-300">{desc}</p>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <div class="hud-panel rounded-lg p-4">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">{lang === 'zh' ? '攻擊手法' : 'Attack Technique'}</p>
          <p class="mt-2 text-white">{demo.attack_technique}</p>
        </div>
        <div class="hud-panel rounded-lg p-4">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">MITRE ATT&CK</p>
          {demo.mitre_attack_url ? (
            <a href={demo.mitre_attack_url} target="_blank" class="mt-2 block text-sky-200 hover:text-sky-100">
              {demo.mitre_attack_id} &nearr;
            </a>
          ) : (
            <p class="mt-2 text-white">{demo.mitre_attack_id}</p>
          )}
        </div>
      </div>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div class="hud-panel rounded-lg p-4">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">{lang === 'zh' ? '影響平台' : 'Platforms'}</p>
          <div class="mt-2 flex flex-wrap gap-2">
            {demo.platforms.map((p: string) => (
              <span class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-0.5 font-mono text-xs text-slate-300">{p}</span>
            ))}
          </div>
        </div>
        <div class="hud-panel rounded-lg p-4">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">{lang === 'zh' ? '檔案類型' : 'File Types'}</p>
          <div class="mt-2 flex flex-wrap gap-2">
            {demo.file_types.map((t: string) => (
              <span class="rounded-md border border-white/10 bg-white/[0.04] px-2 py-0.5 font-mono text-xs text-slate-300">.{t}</span>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-6">
        <div class="hud-panel rounded-lg p-4">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-emerald-200">{lang === 'zh' ? 'MetaDefender 防護能力' : 'MetaDefender Capabilities'}</p>
          <div class="mt-3 flex flex-wrap gap-2">
            {demo.metadefender_capabilities.map((cap: string) => (
              <span class="rounded-md border border-emerald-300/20 bg-emerald-300/[0.08] px-3 py-1.5 text-sm text-emerald-200">
                {cap}
              </span>
            ))}
          </div>
        </div>
      </div>

      {demo.screenshots && demo.screenshots.length > 0 && (
        <div class="mt-8">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">{lang === 'zh' ? '螢幕截圖' : 'Screenshots'}</p>
          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            {demo.screenshots.map((s: { label: string; src: string }) => (
              <div class="hud-panel rounded-lg p-4">
                <p class="mb-2 text-sm text-slate-300">{s.label}</p>
                <div class="aspect-video rounded-md border border-white/10 bg-slate-950/60 flex items-center justify-center">
                  <p class="text-xs text-slate-500">{lang === 'zh' ? '截圖準備中' : 'Screenshot pending'}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={demo.github_url || '#'}
          target="_blank"
          class={`inline-flex items-center gap-2 rounded-lg px-5 py-2.5 font-semibold transition ${demo.github_url ? 'bg-sky-300/15 text-sky-100 hover:bg-sky-300/25' : 'pointer-events-none opacity-40'}`}
        >
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          GitHub
        </a>
        <a
          href={demo.download_url || '#'}
          class={`inline-flex items-center gap-2 rounded-lg px-5 py-2.5 font-semibold transition ${demo.download_url ? 'bg-emerald-300/15 text-emerald-100 hover:bg-emerald-300/25' : 'pointer-events-none opacity-40'}`}
        >
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          {lang === 'zh' ? '下載示範包' : 'Download Demo'}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
---

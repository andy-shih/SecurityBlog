---
import type { CollectionEntry } from 'astro:content';
import ArticleCard from '@/components/ArticleCard.astro';
import BaseLayout from '@/components/BaseLayout.astro';
import { profile } from '@/config/profile';
import type { Lang } from '@/i18n';
import { ui } from '@/i18n';

interface Props {
  lang: Lang;
  posts: CollectionEntry<'blog'>[];
}

const { lang, posts } = Astro.props;
const t = ui[lang];
const latestPosts = posts.slice(0, 4);
---

<BaseLayout
  title="Home"
  description={`${profile.siteName} security notes by ${profile.name}.`}
  lang={lang}
  currentPath="/"
>
  <section class="px-5 py-16 sm:py-20 lg:py-24">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
      <div class="space-y-8">
        <div class="inline-flex rounded-md border border-sky-300/25 bg-sky-300/[0.08] px-3 py-2 font-mono text-xs uppercase tracking-[0.2em] text-sky-200">
          {t.heroEyebrow}
        </div>
        <div class="space-y-5">
          <h1 class="max-w-4xl text-4xl font-bold leading-[1.06] text-white sm:text-5xl lg:text-6xl">
            {profile.siteName}
          </h1>
          <h2 class="max-w-3xl text-2xl font-semibold leading-tight text-sky-100 sm:text-3xl">
            {t.heroSubtitle}
          </h2>
          <p class="max-w-2xl text-lg leading-8 text-slate-300">
            {t.tagline}
          </p>
        </div>
      </div>
      <div class="scanline hud-panel rounded-lg p-5">
        <div class="mb-4 flex items-center justify-between border-b border-white/10 pb-3 font-mono text-xs text-slate-400">
          <span>professional-scope.log</span>
          <span class="text-emerald-200">OPSWAT</span>
        </div>
        <div class="space-y-4 font-mono text-sm text-slate-300">
          <p class="terminal-line max-w-full text-emerald-200">map expertise --focus=critical-infrastructure</p>
          <div class="grid gap-3 pt-3 sm:grid-cols-2">
            {profile.expertise.slice(0, 6).map((item) => (
              <div class="rounded-md border border-white/10 bg-white/[0.03] p-3">
                <span class="text-sky-200">check</span>
                <p class="mt-2 text-sm leading-6 text-slate-300">{item}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-5 py-12">
    <div class="mx-auto max-w-6xl">
      <div class="mb-8">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Latest writing</p>
        <h2 class="mt-3 text-3xl font-bold text-white">{t.latest}</h2>
      </div>
      <div class="grid gap-4 md:grid-cols-2" data-testid="featured-articles">
        {latestPosts.map((post, index) => <ArticleCard post={post} lang={lang} index={index} />)}
      </div>
    </div>
  </section>
</BaseLayout>

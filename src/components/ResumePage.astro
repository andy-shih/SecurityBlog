---
import BaseLayout from '@/components/BaseLayout.astro';
import { profile } from '@/config/profile';
import type { Lang } from '@/i18n';
import { ui } from '@/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
---

<BaseLayout title="Resume" description={`Resume for ${profile.name}.`} lang={lang} currentPath="/resume/">
  <section class="px-5 py-16">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <aside class="space-y-6">
        <div class="hud-panel rounded-lg p-6">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Resume</p>
          <h1 class="mt-4 text-4xl font-bold text-white">Resume / {profile.name}</h1>
          <p class="mt-3 text-xl text-emerald-200">{profile.title} / {profile.titleZh}</p>
          <p class="mt-5 leading-8 text-slate-300">{lang === 'zh' ? profile.taglineZh : profile.tagline}</p>
          <div class="mt-6 grid gap-3 text-sm text-slate-300">
            <span>{profile.location}</span>

          </div>
        </div>
      </aside>

      <div class="space-y-8">
        <section>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-emerald-200">Profile</p>
          <h2 class="mt-3 text-3xl font-bold text-white">{t.resumeProfile}</h2>
          <p class="mt-4 leading-8 text-slate-300">{t.resumeIntro}</p>
        </section>

        <section data-testid="experience">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Experience</p>
          <div class="mt-4 grid gap-4">
            {profile.experience.map((item) => (
              <div class="hud-panel rounded-lg p-5">
                <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
                  <h3 class="font-semibold text-white">{item.role}</h3>
                  <p class="font-mono text-xs uppercase tracking-[0.14em] text-emerald-200">{item.period}</p>
                </div>
                <p class="mt-2 font-mono text-sm text-sky-200">{item.company}</p>
                <p class="mt-2 text-sm leading-6 text-slate-400">{item.summary}</p>
              </div>
            ))}
          </div>
        </section>

        <section>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Expertise</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {[...profile.focus, ...profile.expertise].map((item) => (
              <span class="rounded-md border border-white/10 bg-white/[0.04] px-3 py-2 text-sm text-slate-200">{item}</span>
            ))}
          </div>
        </section>

        <section data-testid="credentials">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Credentials</p>
          <ul class="mt-4 grid gap-3 text-slate-300">
            {profile.certifications.map((certification) => (
              <li class="rounded-md border border-white/10 bg-slate-950/45 p-4">{certification}</li>
            ))}
          </ul>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>

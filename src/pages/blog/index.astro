---
import { getCollection } from 'astro:content';
import ArticleCard from '@/components/ArticleCard.astro';
import BaseLayout from '@/components/BaseLayout.astro';
import { sortPosts } from '@/utils/posts';

const posts = sortPosts(await getCollection('blog'));
---

<BaseLayout title="Blog" description="Five practical cyber security articles for consultants, founders, and technical teams.">
  <section class="px-5 py-16">
    <div class="mx-auto max-w-6xl">
      <div class="max-w-3xl">
        <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Cyber security blog</p>
        <h1 class="mt-4 text-4xl font-bold text-white sm:text-5xl">Security Field Notes</h1>
        <p class="mt-5 text-lg leading-8 text-slate-300">
          寫給需要做決策的人：把攻防觀察、雲端邊界、事件應變與員工韌性，整理成能被執行的資安行動。
        </p>
      </div>
      <div class="mt-10 grid gap-4 md:grid-cols-2" data-testid="blog-list">
        {posts.map((post, index) => <ArticleCard post={post} index={index} />)}
      </div>
    </div>
  </section>
</BaseLayout>

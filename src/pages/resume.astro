---
import BaseLayout from '@/components/BaseLayout.astro';
import { profile } from '@/config/profile';
---

<BaseLayout title="Resume" description="Bilingual resume for a cyber security consultant focused on risk reduction, security assessments, and incident readiness.">
  <section class="px-5 py-16">
    <div class="mx-auto grid max-w-6xl gap-10 lg:grid-cols-[0.9fr_1.1fr]">
      <aside class="space-y-6">
        <div class="hud-panel rounded-lg p-6">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Resume</p>
          <h1 class="mt-4 text-4xl font-bold text-white">Resume / {profile.name}</h1>
          <p class="mt-3 text-xl text-emerald-200">{profile.title} / {profile.titleZh}</p>
          <p class="mt-5 leading-8 text-slate-300">{profile.taglineZh}</p>
          <div class="mt-6 grid gap-3 text-sm text-slate-300">
            <span>{profile.location}</span>
            <a class="text-sky-200 hover:text-sky-100" href={`mailto:${profile.email}`}>{profile.email}</a>
            <a class="text-sky-200 hover:text-sky-100" href={profile.github}>GitHub</a>
            <a class="text-sky-200 hover:text-sky-100" href={profile.linkedin}>LinkedIn</a>
          </div>
          <a class="mt-6 inline-flex rounded-md bg-emerald-300 px-5 py-3 font-semibold text-slate-950 transition hover:bg-emerald-200" href={`mailto:${profile.email}`}>
            Contact for consulting
          </a>
        </div>
      </aside>

      <div class="space-y-8">
        <section>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-emerald-200">Profile</p>
          <h2 class="mt-3 text-3xl font-bold text-white">資安風險轉譯與落地執行</h2>
          <p class="mt-4 leading-8 text-slate-300">
            這是一份可替換的個人品牌簡歷範本。第一版聚焦於資安顧問能力：安全評估、事件應變準備、雲端與邊界安全、以及能讓管理層採取行動的風險溝通。
          </p>
          <p class="mt-4 leading-8 text-slate-400">
            This profile is structured for consulting conversations: it explains the security problems you solve, the systems you review, and the business outcomes you help teams reach.
          </p>
        </section>

        <section data-testid="services">
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Services</p>
          <div class="mt-4 grid gap-4 md:grid-cols-2">
            {profile.services.map((service) => (
              <div class="hud-panel rounded-lg p-5">
                <h3 class="font-semibold text-white">{service}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-400">
                  Scope, findings, priority, and remediation guidance tailored for technical and executive stakeholders.
                </p>
              </div>
            ))}
          </div>
        </section>

        <section>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Expertise</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {profile.expertise.map((item) => (
              <span class="rounded-md border border-white/10 bg-white/[0.04] px-3 py-2 text-sm text-slate-200">{item}</span>
            ))}
          </div>
        </section>

        <section>
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-sky-200">Credentials</p>
          <ul class="mt-4 grid gap-3 text-slate-300">
            {profile.certifications.map((certification) => (
              <li class="rounded-md border border-white/10 bg-slate-950/45 p-4">{certification}</li>
            ))}
          </ul>
        </section>
      </div>
    </div>
  </section>
</BaseLayout>
